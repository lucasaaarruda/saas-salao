# =============================================================
# BANCO DE DADOS
# =============================================================
POSTGRES_DB=salao_db
POSTGRES_USER=salao_user
POSTGRES_PASSWORD=salao_pass
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://salao_user:salao_pass@postgres:5432/salao_db

# =============================================================
# REDIS
# =============================================================
REDIS_URL=redis://redis:6379/0

# =============================================================
# SEGURANÇA / JWT
# =============================================================
SECRET_KEY=troque-esta-chave-em-producao-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================
# EMAIL (SMTP)
# =============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASSWORD=sua-senha-de-app
EMAILS_FROM_NAME=Salão App
EMAILS_FROM_EMAIL=noreply@salaoapp.com.br

# =============================================================
# APLICAÇÃO
# =============================================================
AMBIENTE=development
BACKEND_CORS_ORIGINS=["http://localhost:5173"]
PRIMEIRO_ADMIN_EMAIL=admin@admin.com
PRIMEIRO_ADMIN_SENHA=Admin123!

# =============================================================
# STORAGE (logos e fotos)
# =============================================================
STORAGE_TYPE=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# =============================================================
# FRONTEND — variáveis públicas (prefixo VITE_ obrigatório)
# =============================================================
VITE_API_URL=http://localhost:8000/api/v1
VITE_APP_NOME=Salão App
VITE_APP_VERSAO=1.0.0
