# =============================================================
# BANCO DE DADOS
# =============================================================
POSTGRES_DB=salao_db
POSTGRES_USER=salao_user
POSTGRES_PASSWORD=TROQUE_AQUI
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://salao_user:TROQUE_AQUI@postgres:5432/salao_db

# =============================================================
# REDIS
# =============================================================
REDIS_URL=redis://redis:6379/0

# =============================================================
# SEGURANÇA / JWT
# Gere a SECRET_KEY com: openssl rand -hex 32
# =============================================================
SECRET_KEY=TROQUE_AQUI_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================
# WHATSAPP — Evolution API
# EVOLUTION_API_URL: URL base da sua instância Evolution API
#   Ex: https://evolution.seudominio.com.br
# EVOLUTION_API_KEY: chave de autenticação da API
# EVOLUTION_INSTANCE: nome da instância conectada ao WhatsApp
#   (o número que vai enviar as mensagens)
# FRONTEND_URL: URL pública do frontend (usada nos links das mensagens)
# =============================================================
EVOLUTION_API_URL=https://evolution.seudominio.com.br
EVOLUTION_API_KEY=TROQUE_AQUI
EVOLUTION_INSTANCE=nome-da-instancia
FRONTEND_URL=https://seudominio.com.br

# =============================================================
# APLICAÇÃO
# AMBIENTE: development | production
# =============================================================
AMBIENTE=development
BACKEND_CORS_ORIGINS=["http://localhost:5173"]
ALLOWED_HOSTS=["localhost","127.0.0.1"]
PRIMEIRO_ADMIN_EMAIL=admin@salaoapp.com.br
PRIMEIRO_ADMIN_SENHA=TROQUE_AQUI

# =============================================================
# STORAGE (logos e fotos)
# STORAGE_TYPE: local | s3
# =============================================================
STORAGE_TYPE=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# =============================================================
# FRONTEND — variáveis públicas (prefixo VITE_ obrigatório)
# Injetadas pelo Vite em build time, visíveis no browser
# =============================================================
VITE_API_URL=http://localhost:8000/api/v1
VITE_APP_NOME=Salão App
VITE_APP_VERSAO=1.0.0
