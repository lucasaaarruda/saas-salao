# =============================================================
# BANCO DE DADOS
# =============================================================
POSTGRES_DB=salao_db
POSTGRES_USER=salao_user
POSTGRES_PASSWORD=TROQUE_AQUI
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://salao_user:TROQUE_AQUI@postgres:5432/salao_db

# =============================================================
# REDIS
# =============================================================
REDIS_URL=redis://redis:6379/0

# =============================================================
# SEGURANÇA / JWT
# Gere a SECRET_KEY com: openssl rand -hex 32
# =============================================================
SECRET_KEY=TROQUE_AQUI_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================
# EMAIL (SMTP)
# Para Gmail: use senha de app (não a senha principal)
# =============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASSWORD=sua-senha-de-app
EMAILS_FROM_NAME=Salão App
EMAILS_FROM_EMAIL=noreply@salaoapp.com.br

# =============================================================
# APLICAÇÃO
# AMBIENTE: development | production
# =============================================================
AMBIENTE=development
BACKEND_CORS_ORIGINS=["http://localhost:5173"]
PRIMEIRO_ADMIN_EMAIL=admin@salaoapp.com.br
PRIMEIRO_ADMIN_SENHA=TROQUE_AQUI

# =============================================================
# STORAGE (logos e fotos)
# STORAGE_TYPE: local | s3
# =============================================================
STORAGE_TYPE=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# =============================================================
# FRONTEND — variáveis públicas (prefixo VITE_ obrigatório)
# Injetadas pelo Vite em build time, visíveis no browser
# =============================================================
VITE_API_URL=http://localhost:8000/api/v1
VITE_APP_NOME=Salão App
VITE_APP_VERSAO=1.0.0
